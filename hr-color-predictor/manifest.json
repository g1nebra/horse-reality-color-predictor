{
  "manifest_version": 3,
  "name": "HR color predictor by claymore",
  "version": "0.4.0",
  "description": "Horse Reality colour genetics predictor. Calculate offspring colour outcomes instantly from any horse profile.",

  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://*.horsereality.com/*"],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "content_scripts": [
    {
      "matches": ["https://*.horsereality.com/horses/*"],
      "js": ["topbar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.horsereality.com/horses/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["sidebar/sidebar.html"],
      "matches": ["https://*.horsereality.com/*"]
    }
  ],

  "action": {
    "default_title": "HR Genetics",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    }
  }
}